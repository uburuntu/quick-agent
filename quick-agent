#!/bin/bash
#
# quick-agent — Right-click any folder in Finder to open AI coding agents
# https://github.com/uburuntu/quick-agent
#
# Usage:
#   quick-agent install      Install Finder Quick Actions
#   quick-agent uninstall    Remove Quick Actions and config
#   quick-agent config       Change settings interactively
#   quick-agent status       Show current configuration
#   quick-agent --help       Show help
#   quick-agent --version    Show version
#

set -eo pipefail

VERSION="1.0.0"
REPO="uburuntu/quick-agent"
REPO_URL="https://github.com/${REPO}"
CONFIG_DIR="$HOME/.config/quick-agent"
CONFIG_FILE="$CONFIG_DIR/config"
SERVICES_DIR="$HOME/Library/Services"

# ── Formatting ───────────────────────────────────────────────────

_bold()   { printf '\033[1m%s\033[0m' "$*"; }
_dim()    { printf '\033[2m%s\033[0m' "$*"; }
_green()  { printf '\033[32m%s\033[0m' "$*"; }
_red()    { printf '\033[31m%s\033[0m' "$*"; }
_cyan()   { printf '\033[36m%s\033[0m' "$*"; }
_yellow() { printf '\033[33m%s\033[0m' "$*"; }

_ok()   { printf "    $(_green '✓') %s\n" "$*"; }
_fail() { printf "    $(_red '✗') %s\n" "$*"; }
_info() { printf "    $(_dim '·') %s\n" "$*"; }

# ── Agent Registry ───────────────────────────────────────────────

ALL_AGENTS="claude codex gemini aider cursor"

agent_name() {
    case "$1" in
        claude) echo "Claude Code" ;;
        codex)  echo "Codex" ;;
        gemini) echo "Gemini" ;;
        aider)  echo "Aider" ;;
        cursor) echo "Cursor" ;;
        *)      echo "$1" ;;
    esac
}

agent_cmd() {
    echo "$1"
}

agent_type() {
    case "$1" in
        cursor) echo "gui" ;;
        *)      echo "terminal" ;;
    esac
}

agent_install_hint() {
    case "$1" in
        claude) echo "curl -fsSL https://claude.ai/install.sh | bash" ;;
        codex)  echo "npm i -g @openai/codex" ;;
        gemini) echo "npm i -g @anthropic-ai/gemini-cli" ;;
        aider)  echo "pip install aider-chat" ;;
        cursor) echo "Download from https://cursor.com" ;;
    esac
}

agent_is_installed() {
    _augment_path
    case "$1" in
        cursor)
            [ -d "/Applications/Cursor.app" ] || command -v cursor &>/dev/null
            ;;
        *)
            command -v "$1" &>/dev/null
            ;;
    esac
}

# ── Terminal Registry ────────────────────────────────────────────

ALL_TERMINALS="terminal iterm2 ghostty warp"

terminal_name() {
    case "$1" in
        terminal) echo "Terminal.app" ;;
        iterm2)   echo "iTerm2" ;;
        ghostty)  echo "Ghostty" ;;
        warp)     echo "Warp" ;;
        *)        echo "$1" ;;
    esac
}

terminal_is_installed() {
    case "$1" in
        terminal) return 0 ;; # Always available
        iterm2)   [ -d "/Applications/iTerm.app" ] ;;
        ghostty)  [ -d "/Applications/Ghostty.app" ] ;;
        warp)     [ -d "/Applications/Warp.app" ] ;;
        *)        return 1 ;;
    esac
}

# ── PATH ─────────────────────────────────────────────────────────

_augment_path() {
    local p
    for p in \
        "/usr/local/bin" \
        "/opt/homebrew/bin" \
        "/opt/homebrew/sbin" \
        "$HOME/.local/bin" \
        "$HOME/.cargo/bin" \
    ; do
        case ":$PATH:" in
            *":$p:"*) ;;
            *) [ -d "$p" ] && export PATH="$p:$PATH" ;;
        esac
    done
    # nvm
    if [ -d "$HOME/.nvm/versions/node" ]; then
        local node_dir
        node_dir=$(ls -d "$HOME/.nvm/versions/node/"*/bin 2>/dev/null | sort -V | tail -1)
        [ -n "$node_dir" ] && export PATH="$node_dir:$PATH"
    fi
    # pyenv
    [ -d "$HOME/.pyenv/shims" ] && export PATH="$HOME/.pyenv/shims:$PATH"
    return 0
}

# ── Config ───────────────────────────────────────────────────────

config_get() {
    local key="$1" default="${2:-}"
    if [ -f "$CONFIG_FILE" ]; then
        local val
        val=$(grep "^${key}=" "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2-)
        echo "${val:-$default}"
    else
        echo "$default"
    fi
}

config_set() {
    local key="$1" value="$2"
    mkdir -p "$CONFIG_DIR"
    if [ -f "$CONFIG_FILE" ] && grep -q "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
        local tmp; tmp=$(mktemp)
        sed "s|^${key}=.*|${key}=${value}|" "$CONFIG_FILE" > "$tmp"
        mv "$tmp" "$CONFIG_FILE"
    else
        echo "${key}=${value}" >> "$CONFIG_FILE"
    fi
}

# ── Detection ────────────────────────────────────────────────────

auto_select_terminal() {
    local id
    for id in iterm2 ghostty warp terminal; do
        terminal_is_installed "$id" && echo "$id" && return
    done
    echo "terminal"
}

auto_select_agent() {
    local id
    for id in $ALL_AGENTS; do
        agent_is_installed "$id" && echo "$id" && return
    done
}

# ── Binary Self-Install ─────────────────────────────────────────
# Ensure quick-agent is in a PATH location so workflows can find it.

_ensure_binary_in_path() {
    # Already accessible?
    for p in /usr/local/bin /opt/homebrew/bin "$HOME/.local/bin"; do
        [ -x "$p/quick-agent" ] && return 0
    done

    # Resolve path to the currently running script
    local self
    self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

    # Pick a writable PATH location
    local target=""
    if [ -w "/usr/local/bin" ]; then
        target="/usr/local/bin/quick-agent"
    else
        mkdir -p "$HOME/.local/bin" 2>/dev/null || true
        target="$HOME/.local/bin/quick-agent"
    fi

    cp "$self" "$target" && chmod +x "$target"
    _ok "Installed CLI to ${target}"
    return 0
}

# ── AppleScript Helpers ──────────────────────────────────────────

_as_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

# ── Terminal Launch Functions ────────────────────────────────────

_launch_terminal_app() {
    local dir="$1" cmd="$2"
    local edir; edir=$(_as_escape "$dir")
    osascript <<EOF
tell application "Terminal"
    activate
    do script "cd \"${edir}\" && ${cmd}"
end tell
EOF
}

_launch_iterm2() {
    local dir="$1" cmd="$2"
    local edir; edir=$(_as_escape "$dir")
    osascript <<EOF
tell application "iTerm2"
    activate
    set newWindow to (create window with default profile)
    tell current session of newWindow
        write text "cd \"${edir}\" && ${cmd}"
    end tell
end tell
EOF
}

_launch_ghostty() {
    local dir="$1" cmd="$2"
    local edir; edir=$(_as_escape "$dir")
    # Try native AppleScript (Ghostty v1.3.0+)
    if osascript <<EOF 2>/dev/null
tell application "Ghostty"
    activate
    set cfg to new surface configuration
    set initial working directory of cfg to "${edir}"
    set win to new window with configuration cfg
    set term to focused terminal of selected tab of win
    input text "${cmd}" & return to term
end tell
EOF
    then
        return 0
    fi
    # Fallback: open via CLI
    open -na Ghostty --args --working-directory="${dir}"
}

_launch_warp() {
    local dir="$1" cmd="$2"
    # Warp doesn't support AppleScript or passing commands via URI.
    # Use a temporary Launch Configuration YAML.
    local cfg_name="quick-agent-$$"
    local cfg_dir="$HOME/.warp/launch_configurations"
    mkdir -p "$cfg_dir"
    local yaml_dir; yaml_dir=$(printf '%s' "$dir" | sed 's/"/\\"/g')
    cat > "${cfg_dir}/${cfg_name}.yaml" <<YAML
---
name: ${cfg_name}
windows:
  - tabs:
    - title: Quick Agent
      layout:
        cwd: "${yaml_dir}"
        commands:
          - exec: ${cmd}
YAML
    open "warp://launch/${cfg_name}"
    # Clean up temp config after delay
    (sleep 10 && rm -f "${cfg_dir}/${cfg_name}.yaml") &>/dev/null &
}

_launch_in() {
    local terminal_id="$1" dir="$2" cmd="$3"
    case "$terminal_id" in
        terminal) _launch_terminal_app "$dir" "$cmd" ;;
        iterm2)   _launch_iterm2 "$dir" "$cmd" ;;
        ghostty)  _launch_ghostty "$dir" "$cmd" ;;
        warp)     _launch_warp "$dir" "$cmd" ;;
        *)        _launch_terminal_app "$dir" "$cmd" ;;
    esac
}

