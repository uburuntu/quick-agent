_create_workflow() {
    local name="$1" command_string="$2" icon="${3:-terminal}"
    local wf_dir="${SERVICES_DIR}/${name}.workflow/Contents"
    mkdir -p "$wf_dir"
    _generate_info_plist "$name" "$icon" > "$wf_dir/Info.plist"
    _generate_document_wflow "$command_string" > "$wf_dir/document.wflow"
}

# ── The shell script embedded in each workflow ───────────────────
# Automator runs with a minimal PATH, so we prepend common locations
# then delegate to the quick-agent binary.

_wf_script() {
    local mode="$1"
    # Single-quoted heredoc prevents $HOME/$PATH/$1 expansion at generation time.
    # These get expanded at RUNTIME when Automator's bash runs the script.
    cat <<'__HEADER__'
export PATH="/usr/local/bin:/opt/homebrew/bin:$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
if [ -d "$HOME/.nvm/versions/node" ]; then
  nd=$(ls -d "$HOME/.nvm/versions/node/"*/bin 2>/dev/null | sort -V | tail -1)
  [ -n "$nd" ] && export PATH="$nd:$PATH"
fi
[ -d "$HOME/.pyenv/shims" ] && export PATH="$HOME/.pyenv/shims:$PATH"
__HEADER__
    printf 'exec quick-agent _run %s "$1"\n' "$mode"
}

# ── Workflow Install / Remove ────────────────────────────────────

_install_workflows() {
    local default_agent; default_agent=$(config_get "default_agent" "claude")
    local display_name; display_name=$(agent_name "$default_agent")

    # 1. Default agent — one click to launch
    _create_workflow "Open in ${display_name}" "$(_wf_script default)" "terminal"
    _ok "Open in ${display_name}"

    # 2. Agent chooser — pick from all installed agents
    _create_workflow "Open in Agent..." "$(_wf_script choose)" "ellipsis.circle"
    _ok "Open in Agent..."

    # 3. Settings
    _create_workflow "Quick Agent Settings" "$(_wf_script setup)" "gear"
    _ok "Quick Agent Settings"

    # Refresh services database and restart Finder to pick up new actions
    /System/Library/CoreServices/pbs -flush 2>/dev/null || true
    killall pbs 2>/dev/null || true
    killall Finder 2>/dev/null || true
}

_remove_workflows() {
    local wf
    for wf in "$SERVICES_DIR"/Open\ in\ *.workflow "$SERVICES_DIR"/Quick\ Agent\ Settings.workflow; do
        if [ -d "$wf" ]; then
            rm -rf "$wf"
            _ok "Removed: $(basename "$wf" .workflow)"
        fi
    done
    /System/Library/CoreServices/pbs -flush 2>/dev/null || true
    return 0
}

# ── cmd: install ─────────────────────────────────────────────────

cmd_install() {
    _augment_path
    echo ""
    printf "  $(_bold '⚡ Quick Agent') v${VERSION}\n"
    echo ""

    # ── Ensure binary is in PATH ──
    _ensure_binary_in_path

    # ── Scan agents ──
    printf "  Scanning for AI coding agents...\n"
    local installed_agents=""
    local id
    for id in $ALL_AGENTS; do
        if agent_is_installed "$id"; then
            _ok "$(printf '%-8s' "$id") — $(agent_name "$id")"
            installed_agents="${installed_agents} ${id}"
        else
            _fail "$(printf '%-8s' "$id") — $(_dim 'not found')"
        fi
    done
    installed_agents="${installed_agents# }"  # trim leading space

    if [ -z "$installed_agents" ]; then
        echo ""
        printf "  $(_red 'No AI agents found.') Install at least one:\n"
        for id in $ALL_AGENTS; do
            printf "    • %s:  %s\n" "$(agent_name "$id")" "$(agent_install_hint "$id")"
        done
        echo ""
        exit 1
    fi
    echo ""

    # ── Scan terminals ──
    printf "  Scanning for terminal apps...\n"
    for id in $ALL_TERMINALS; do
        if terminal_is_installed "$id"; then
            _ok "$(terminal_name "$id")"
        else
            _fail "$(terminal_name "$id") — $(_dim 'not found')"
        fi
    done
    echo ""

    # ── Auto-select defaults ──
    local default_agent; default_agent=$(auto_select_agent)
    local default_terminal; default_terminal=$(auto_select_terminal)

    local show_summary=true
    while $show_summary; do
        printf "  ─────────────────────────────────\n"
        printf "  Default agent:  $(_bold "$(agent_name "$default_agent")")\n"
        printf "  Terminal:       $(_bold "$(terminal_name "$default_terminal")")\n"
        printf "  ─────────────────────────────────\n"
        echo ""

        printf "  Install with these settings? [$(_bold 'Y')/n/c] "
        read -r choice
        case "${choice:-y}" in
            [Yy]|[Yy]es|"")
                show_summary=false
                ;;
            [Nn]|[Nn]o)
                echo ""; printf "  Cancelled.\n"; echo ""
                exit 0
                ;;
            [Cc]|[Cc]onfigure)
                # Pick default agent
                echo ""
                printf "  Choose default agent:\n"
                local i=1 agents_arr=()
                for id in $installed_agents; do
                    agents_arr+=("$id")
                    local marker=""; [ "$id" = "$default_agent" ] && marker=" $(_dim '← current')"
                    printf "    [%d] %s%s\n" "$i" "$(agent_name "$id")" "$marker"
                    i=$((i + 1))
                done
                printf "  Choice: "
                read -r achoice
                if [ -n "$achoice" ] && [ "$achoice" -ge 1 ] 2>/dev/null && [ "$achoice" -le "${#agents_arr[@]}" ] 2>/dev/null; then
                    default_agent="${agents_arr[$((achoice - 1))]}"
                fi

                # Pick terminal
                echo ""
                printf "  Choose terminal:\n"
                i=1
                local terms_arr=()
                for id in $ALL_TERMINALS; do
                    if terminal_is_installed "$id"; then
                        terms_arr+=("$id")
                        local marker=""; [ "$id" = "$default_terminal" ] && marker=" $(_dim '← current')"
                        printf "    [%d] %s%s\n" "$i" "$(terminal_name "$id")" "$marker"
                        i=$((i + 1))
                    fi
                done
                printf "  Choice: "
                read -r tchoice
                if [ -n "$tchoice" ] && [ "$tchoice" -ge 1 ] 2>/dev/null && [ "$tchoice" -le "${#terms_arr[@]}" ] 2>/dev/null; then
                    default_terminal="${terms_arr[$((tchoice - 1))]}"
                fi
                echo ""
                ;;
        esac
    done
    echo ""

    # Save config
    config_set "default_agent" "$default_agent"
    config_set "terminal" "$default_terminal"

    # Remove old workflows (silently)
    _remove_workflows 2>/dev/null || true

    # Install
    printf "  Installing Quick Actions...\n"
    _install_workflows

    echo ""
    printf "  ✨ $(_bold 'Done!') Right-click any folder in Finder to try it.\n"
    echo ""
    printf "  $(_dim 'Quick Actions appear under: right-click → Quick Actions')\n"
    printf "  $(_dim 'If they don'\''t show up:')\n"
    printf "  $(_dim '  1. Right-click a folder → Quick Actions → Customize...')\n"
    printf "  $(_dim '  2. Or: System Settings → Privacy & Security → Extensions → Finder')\n"
    printf "  $(_dim '  3. Enable the Quick Agent actions')\n"
    echo ""
}

# ── cmd: uninstall ───────────────────────────────────────────────

cmd_uninstall() {
    echo ""
    printf "  $(_bold '⚡ Quick Agent') — Uninstall\n"
    echo ""

    printf "  Removing Quick Actions...\n"
    _remove_workflows 2>/dev/null || printf "    $(_dim 'No workflows found.')\n"

    if [ -d "$CONFIG_DIR" ]; then
        rm -rf "$CONFIG_DIR"
        _ok "Removed configuration"
    fi

    echo ""
    printf "  ✨ $(_bold 'Done!') All Quick Actions have been removed.\n"
    echo ""
    local bin_path; bin_path=$(command -v quick-agent 2>/dev/null || echo "/usr/local/bin/quick-agent")
    printf "  $(_dim "To also remove the CLI:  rm ${bin_path}")\n"
    echo ""
}

# ── cmd: config ──────────────────────────────────────────────────

cmd_config() {
    _augment_path
    echo ""
    printf "  $(_bold '⚡ Quick Agent') — Settings\n"
    echo ""

    local current_agent; current_agent=$(config_get "default_agent" "claude")
    local current_terminal; current_terminal=$(config_get "terminal" "terminal")

    printf "  Default agent:  $(_bold "$(agent_name "$current_agent")")\n"
    printf "  Terminal:       $(_bold "$(terminal_name "$current_terminal")")\n"
    echo ""
    printf "  [1] Change default agent\n"
    printf "  [2] Change terminal\n"
    printf "  [3] Reinstall Quick Actions\n"
    printf "  [q] Quit\n"
    echo ""
    printf "  Choice: "
    read -r choice

    local needs_reinstall=false

    case "$choice" in
        1)
            echo ""
            printf "  Available agents:\n"
            local i=1 agents_arr=()
            for id in $ALL_AGENTS; do
                agents_arr+=("$id")
                local status marker=""
                agent_is_installed "$id" && status="$(_green '✓')" || status="$(_red '✗')"
                [ "$id" = "$current_agent" ] && marker=" $(_dim '← current')"
                printf "    %s [%d] %s%s\n" "$status" "$i" "$(agent_name "$id")" "$marker"
                i=$((i + 1))
            done
            printf "  Choice: "
            read -r achoice
            if [ -n "$achoice" ] && [ "$achoice" -ge 1 ] 2>/dev/null && [ "$achoice" -le "${#agents_arr[@]}" ] 2>/dev/null; then
                local new_agent="${agents_arr[$((achoice - 1))]}"
                if [ "$new_agent" != "$current_agent" ]; then
                    config_set "default_agent" "$new_agent"
                    _ok "Default agent → $(agent_name "$new_agent")"
                    needs_reinstall=true
                fi
            fi
            ;;
        2)
            echo ""
            printf "  Available terminals:\n"
            local i=1 terms_arr=()
            for id in $ALL_TERMINALS; do
                terms_arr+=("$id")
                local status marker=""
                terminal_is_installed "$id" && status="$(_green '✓')" || status="$(_red '✗')"
                [ "$id" = "$current_terminal" ] && marker=" $(_dim '← current')"
                printf "    %s [%d] %s%s\n" "$status" "$i" "$(terminal_name "$id")" "$marker"
                i=$((i + 1))
            done
            printf "  Choice: "
            read -r tchoice
            if [ -n "$tchoice" ] && [ "$tchoice" -ge 1 ] 2>/dev/null && [ "$tchoice" -le "${#terms_arr[@]}" ] 2>/dev/null; then
                local new_terminal="${terms_arr[$((tchoice - 1))]}"
                if [ "$new_terminal" != "$current_terminal" ]; then
                    config_set "terminal" "$new_terminal"
                    _ok "Terminal → $(terminal_name "$new_terminal")"
                fi
            fi
            ;;
        3)  needs_reinstall=true ;;
        [Qq]|"") echo ""; return ;;
    esac

    if $needs_reinstall; then
        echo ""
        printf "  Reinstalling Quick Actions...\n"
        _remove_workflows 2>/dev/null || true
        _install_workflows
        echo ""
        printf "  ✨ $(_bold 'Done!')\n"
    fi
    echo ""
}

# ── cmd: status ──────────────────────────────────────────────────

cmd_status() {
    _augment_path
    echo ""
    printf "  $(_bold '⚡ Quick Agent') v${VERSION}\n"
    echo ""

    if [ ! -f "$CONFIG_FILE" ]; then
        printf "  $(_yellow 'Not configured.') Run: quick-agent install\n"
        echo ""
        return
    fi

    local current_agent; current_agent=$(config_get "default_agent" "claude")
    local current_terminal; current_terminal=$(config_get "terminal" "terminal")

    printf "  Default agent:  $(_bold "$(agent_name "$current_agent")")"
    agent_is_installed "$current_agent" && printf " $(_green '✓')" || printf " $(_red '✗ not in PATH')"
    echo ""
    printf "  Terminal:       $(_bold "$(terminal_name "$current_terminal")")"
    terminal_is_installed "$current_terminal" && printf " $(_green '✓')" || printf " $(_red '✗ not found')"
    echo ""
    echo ""

    printf "  Installed Quick Actions:\n"
    local found=false
    for wf in "$SERVICES_DIR"/Open\ in\ *.workflow "$SERVICES_DIR"/Quick\ Agent*.workflow; do
        if [ -d "$wf" ]; then
            _ok "$(basename "$wf" .workflow)"
            found=true
        fi
    done
    if ! $found; then printf "    $(_dim 'None found. Run: quick-agent install')\n"; fi
    echo ""
}

# ── cmd: _run (internal — called by Quick Action workflows) ──────

cmd_run() {
    local mode="${1:-default}"
    shift 2>/dev/null || true

    _augment_path

    case "$mode" in
        default) _run_default_agent "$@" ;;
        choose)  _run_choose_agent "$@" ;;
        setup)   _run_setup ;;
        *)       _run_agent "$mode" "$@" ;;
    esac
}

_resolve_dir() {
    local path="$1"
    if [ -d "$path" ]; then
        echo "$path"
    elif [ -f "$path" ]; then
        dirname "$path"
    else
        echo "$HOME"
    fi
}

_ensure_config() {
    [ -f "$CONFIG_FILE" ] && return 0
    # First-run: show a native macOS dialog to pick terminal
    local tlist="" tids=()
    local id
    for id in $ALL_TERMINALS; do
        if terminal_is_installed "$id"; then
            tids+=("$id")
            [ -n "$tlist" ] && tlist="${tlist}, "
            tlist="${tlist}\"$(terminal_name "$id")\""
        fi
    done

    local chosen
    chosen=$(osascript -e "choose from list {${tlist}} with title \"Quick Agent — Setup\" with prompt \"Choose your preferred terminal:\" default items {\"$(terminal_name "${tids[0]}")\"}" 2>/dev/null) || true

    local selected_terminal="terminal"
    if [ "$chosen" != "false" ] && [ -n "$chosen" ]; then
        for id in "${tids[@]}"; do
            [ "$(terminal_name "$id")" = "$chosen" ] && selected_terminal="$id" && break
        done
    fi
    config_set "terminal" "$selected_terminal"
    local default; default=$(auto_select_agent)
    config_set "default_agent" "${default:-claude}"
}

_run_default_agent() {
    local target="${1:-$HOME}"
    _ensure_config
    local agent_id; agent_id=$(config_get "default_agent" "claude")
    _run_agent "$agent_id" "$target"
}

_run_agent() {
    local agent_id="$1" target="${2:-$HOME}"
    _ensure_config
    local dir; dir=$(_resolve_dir "$target")
    local atype; atype=$(agent_type "$agent_id")
    local acmd; acmd=$(agent_cmd "$agent_id")

    # Check if agent is installed
    if ! agent_is_installed "$agent_id"; then
        local hint; hint=$(agent_install_hint "$agent_id")
        osascript -e "display dialog \"$(agent_name "$agent_id") is not installed.

Install with:
${hint}\" with title \"Quick Agent\" buttons {\"OK\"} default button \"OK\" with icon stop" 2>/dev/null || true
        exit 1
    fi

    if [ "$atype" = "gui" ]; then
        open -a "$(agent_name "$agent_id")" "$dir"
    else
        local tid; tid=$(config_get "terminal" "terminal")
        _launch_in "$tid" "$dir" "$acmd"
    fi
}

_run_choose_agent() {
    local target="${1:-$HOME}"
    _ensure_config
    local default_agent; default_agent=$(config_get "default_agent" "claude")

    # Build list of available agents (excluding default, which has its own action)
    local alist="" aids=()
    local id
    for id in $ALL_AGENTS; do
        if agent_is_installed "$id" && [ "$id" != "$default_agent" ]; then
            aids+=("$id")
            [ -n "$alist" ] && alist="${alist}, "
            alist="${alist}\"$(agent_name "$id")\""
        fi
    done

    if [ -z "$alist" ]; then
        osascript -e 'display dialog "No additional AI agents found.

Install more agents and try again." with title "Quick Agent" buttons {"OK"} default button "OK" with icon note' 2>/dev/null || true
        exit 0
    fi

    local chosen
    chosen=$(osascript -e "choose from list {${alist}} with title \"Quick Agent\" with prompt \"Choose an AI agent:\"" 2>/dev/null) || true

    [ "$chosen" = "false" ] || [ -z "$chosen" ] && exit 0

    # Map display name → agent id
    local chosen_id=""
    for id in "${aids[@]}"; do
        [ "$(agent_name "$id")" = "$chosen" ] && chosen_id="$id" && break
    done

    [ -n "$chosen_id" ] && _run_agent "$chosen_id" "$target"
}

_run_setup() {
    _ensure_config
    local tid; tid=$(config_get "terminal" "terminal")
    _launch_in "$tid" "$HOME" "quick-agent config"
}

# ── cmd: help ────────────────────────────────────────────────────

cmd_help() {
    cat <<HELP

  $(_bold '⚡ Quick Agent') v${VERSION}
  Right-click any folder in Finder to open AI coding agents.

  $(_bold 'Usage:')
    quick-agent install       Install Finder Quick Actions
    quick-agent uninstall     Remove Quick Actions and config
    quick-agent config        Change settings (default agent, terminal)
    quick-agent status        Show current configuration

  $(_bold 'Options:')
    --help, -h                Show this help
    --version, -v             Show version

  $(_bold 'Supported agents:')      Claude Code, Codex, Gemini, Aider, Cursor
  $(_bold 'Supported terminals:')   Terminal.app, iTerm2, Ghostty, Warp

  $(_bold 'More info:')             ${REPO_URL}

HELP
}

# ── main ─────────────────────────────────────────────────────────

main() {
    if [ "$(uname)" != "Darwin" ]; then
        printf "  $(_red 'Error:') quick-agent only works on macOS.\n" >&2
        exit 1
    fi

    case "${1:-}" in
        install)        cmd_install ;;
        uninstall)      cmd_uninstall ;;
        config)         cmd_config ;;
        status)         cmd_status ;;
        _run)           shift; cmd_run "$@" ;;
        --help|-h|help) cmd_help ;;
        --version|-v)   echo "quick-agent v${VERSION}" ;;
        "")             cmd_help ;;
        *)
            printf "  $(_red 'Unknown command:') %s\n" "$1" >&2
            printf "  Run '$(_bold 'quick-agent --help')' for usage.\n" >&2
            exit 1
            ;;
    esac
}

main "$@"
